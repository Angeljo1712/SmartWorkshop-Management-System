{
  "name": "smartworkshop-backend",
  "version": "0.1.0",
  "description": "Backend for SmartWorkshop Management System",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "tunnel": "powershell -ExecutionPolicy Bypass -File scripts/dev/tunnel.ps1",
    "tunnel:named": "powershell -ExecutionPolicy Bypass -File scripts/dev/tunnel.ps1 -TunnelName smartworkshop-dev -ConfigPath .cloudflared/tunnel.yml",
    "tunnel:fixed": "powershell -ExecutionPolicy Bypass -File scripts/dev/tunnel-fixed.ps1",
    "tunnel:staging": "powershell -ExecutionPolicy Bypass -File scripts/staging/tunnel-staging.ps1 -Hostname staging.smartworkshop.me",
    "tunnel:staging:named": "powershell -ExecutionPolicy Bypass -File scripts/staging/run-staging-tunnel.ps1",
    "staging:all": "powershell -ExecutionPolicy Bypass -File scripts/staging/start-staging-and-tunnel.ps1",
    "smoke": "node scripts/smoke-test.js",
    "test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.2",
    "nodemailer": "^7.0.13",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
