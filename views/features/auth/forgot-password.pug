extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Forgot Password"
  - var bodyClass = "auth-body"

block head
  link(rel="stylesheet", href="/css/features/auth/auth-shell.css")

block content
  main.auth-shell.auth-shell--forgot
    div.auth-mini-brand.auth-mini-brand--forgot
      span.logo SW
      strong SmartWorkshop
    section.auth-panel.auth-panel--forgot
      .auth-content.auth-content--forgot
        h1 Reset your password
        p.auth-sub Enter your email and we will send a reset link.
        form.auth-form#forgotPasswordForm
          label
            | Email address
            input#forgotPasswordEmail(type="email" placeholder="name@example.com" autocomplete="email")
          p.form-error#forgotPasswordError(role="alert" aria-live="polite")
          button.primary.auth-submit(type="submit") Send link to email
        p.auth-footnote
          a(href="/auth/login") Return to login

append scripts
  script(src="/js/features/auth/auth-pages.js")
