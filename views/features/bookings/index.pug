extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Bookings"
  - var bodyClass = "bookings-body app-shell-body"

block head
  link(rel="stylesheet", href="/css/features/bookings/bookings.css")

block content
  header.main-header.basic-header
    .body-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace
      a.bookings-header-help(href="#") Need help?
  main.primari-shell
    .page-shell-content
      .work-layout1
        .bookings-stepper
          .stepper.stepper--progress-1(aria-label="Booking steps")
            .step.is-complete
              span.step-dot 1
              span.step-label Car
            .step.is-active
              span.step-dot 2
              span.step-label Select work
            .step
              span.step-dot 3
              span.step-label Details
            .step
              span.step-dot 4
              span.step-label Book

        .work-layout2
          .bookings-headline
            h1#bookingsTitle What does your vehicle need?
            p#bookingsSubtitle You're just seconds away from getting a fixed price quote for your car.

          section.bookings-grid(aria-label="Service categories")
            a.bookings-card-link(href="/bookings/work/?type=repair" aria-label="Repairs")
              article.bookings-card
                .bookings-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    path(d="M7 4v8M17 4v12M5 7l2-3 2 3M15 13l2 3 2-3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                    circle(cx="7" cy="14.5" r="2.2" fill="none" stroke="currentColor" stroke-width="1.8")
                    rect(x="15.2" y="16.2" width="3.6" height="3.6" rx="0.8" fill="none" stroke="currentColor" stroke-width="1.8")
                h3 Repairs
                p Know what's wrong? Book in the repair you need.
            a.bookings-card-link(href="/bookings/work/?type=diagnostics" aria-label="Diagnostics")
              article.bookings-card
                .bookings-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    rect(x="4" y="5" width="16" height="11" rx="2" fill="none" stroke="currentColor" stroke-width="1.8")
                    path(d="M7 19h10M9 16v3M15 16v3M7 11h2l1.2-2.2 2.1 4.6 1.6-3 1.1 2.1H17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                h3 Diagnostics
                p Unsure what's wrong? Have a mechanic identify the problem.
            a.bookings-card-link(href="/bookings/work/?type=service" aria-label="Servicing and MOT")
              article.bookings-card
                .bookings-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    rect(x="5" y="3.5" width="14" height="17" rx="2" fill="none" stroke="currentColor" stroke-width="1.8")
                    path(d="M8 8h8M8 11.5h8M8 15h5M16.5 4.5v4M15 6h3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                h3 Servicing & MOT
                p Keep your vehicle safe and in top condition.
            a.bookings-card-link(href="/bookings/work/?type=tyres" aria-label="Tyres")
              article.bookings-card
                .bookings-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    circle(cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.8")
                    circle(cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.8")
                    path(d="M12 4v5M12 15v5M4 12h5M15 12h5M6.3 6.3l3.5 3.5M14.2 14.2l3.5 3.5M17.7 6.3l-3.5 3.5M9.8 14.2l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round")
                h3 Tyres
                p Need a tyre replacement? Book with us online.
            a.bookings-card-link(href="/bookings/work/?type=inspection" aria-label="Pre-purchase inspections")
              article.bookings-card
                .bookings-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    path(d="M5 14.5v-2.2l1.8-4.3h10.4l1.8 4.3v2.2M7.5 16.5h9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                    circle(cx="9" cy="14.5" r="1.2" fill="none" stroke="currentColor" stroke-width="1.6")
                    circle(cx="15" cy="14.5" r="1.2" fill="none" stroke="currentColor" stroke-width="1.6")
                    circle(cx="17.5" cy="8" r="3.2" fill="none" stroke="currentColor" stroke-width="1.8")
                    path(d="M19.8 10.3l2.2 2.2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round")
                h3 Pre-purchase inspections
                p Buying a used car? Have a mechanic check it for you.
  include ../../partials/general-footer

append scripts
  script(src="/js/features/bookings/flow.js")




