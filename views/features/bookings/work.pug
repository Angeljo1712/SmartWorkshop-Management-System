                  .compare-footer
                    span Price
                    span £94.87
                    span £114.29
                    span £163.95
                  .compare-actions
                    span
                    button.primary.compare-service-toggle(type="button" data-service-code="inspection_basic" data-selected="false") Add
                    button.primary.compare-service-toggle(type="button" data-service-code="inspection_standard" data-selected="false") Add
                    button.primary.compare-service-toggle(type="button" data-service-code="inspection_premium" data-selected="false") Add
            else if type === "tyres"
              h2 Choose from popular tyre services
              ul.work-list#serviceList
              p.form-error#serviceListEmpty No services found.
            else
              h2 Search for your repair
              .work-search
                input#serviceSearch(type="text" placeholder="Search available repairs" aria-label="Search available repairs")
              h3 Choose from popular repairs
              ul.work-list#serviceList
              p.form-error#serviceListEmpty No services found.
              a.work-browse-category(href="/bookings/work" aria-label="Browse repairs by category")
                span Or browse by category
                span.work-browse-category-arrow(aria-hidden="true") ›
          aside.work-summary
            .price-card
              .price-head
                span Total price
              .price-main
                span.price-value#summaryTotalWork £0.00
                span.price-note Quote includes VAT where applicable
              .price-vehicle
                span Toyota Corolla 1.4L Petrol 2005 · KT10 0QR
                a(href="/bookings/vehicle") Edit
            .summary-section.is-hidden#workSummarySection
              h3 Selected work
              p.form-error.is-hidden#selectedWorkEmptyWork No items selected yet.
              #selectedWorkListWork
            a.next-step.is-hidden#workNextStep(href="/bookings/details") Next step
            .work-help
              h3 Need help?
              p Tell us what you need and compare fixed-price quotes before you book.
      .service-info-modal.is-hidden#serviceInfoModal(hidden)
        .service-info-modal__backdrop(data-action="close-service-info-modal")
        .service-info-modal__dialog(role="dialog" aria-modal="true" aria-labelledby="serviceInfoModalTitle")
          button.service-info-modal__close(type="button" aria-label="Close service info" data-action="close-service-info-modal") ×
          h2#serviceInfoModalTitle Service details
          p.service-info-modal__lead#serviceInfoModalLead
          .service-info-modal__body#serviceInfoModalBody
  include ../../partials/general-footer

append scripts
  script(src="/js/features/bookings/booking-flow.js")


