                  .compare-row
                    span Manual trans. oil
                    span ✕
                    span ✓
                    span ✓
                  .compare-footer
                    span Price
                    span £123.45
                    span £152.86
                    span £208.25
                  .compare-actions
                    span
                    button.primary.compare-service-toggle(type="button" data-service-code="service_interim" data-selected="false") Add
                    button.primary.compare-service-toggle(type="button" data-service-code="service_full" data-selected="false") Add
                    button.primary.compare-service-toggle(type="button" data-service-code="service_major" data-selected="false") Add
            else if type === "inspection"
              h2 Pre-purchase inspections
              ul.work-list#serviceList
              p.form-error#serviceListEmpty No services found.
              .compare-table
                  .compare-header
                    span Compare
