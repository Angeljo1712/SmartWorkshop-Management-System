extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Bookings"
  - var bodyClass = "bookings-body app-shell-body"

block head
  link(rel="stylesheet", href="/css/features/bookings/booking-flow.css")

block content
  header.main-header.basic-header
    .body-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace
      a.bookings-header-help(href="#") Need help?
  main.primari-shell
    .page-shell-content
      .work-type-layout-1
        - const workTitle = type === "diagnostics" ? "In-person diagnostic" : type === "service" ? "Servicing & MOT" : type === "inspection" ? "Pre-purchase inspections" : type === "tyres" ? "Choose from popular tyre services" : "Search for your repair";
        - const workSubtitle = type === "diagnostics" ? "Get a mechanic to diagnose the issue and give you a no-obligation quote for any required repairs." : type === "service" ? "Compare service levels and choose the right option for your vehicle." : type === "inspection" ? "Choose the inspection depth that matches the vehicle you are checking." : type === "tyres" ? "Pick a tyre service and continue with your booking." : "Find the repair you need or browse the available categories.";
        .bookings-stepper
          .stepper.stepper--progress-2(aria-label="Booking steps")
            .step.is-complete
              span.step-dot 1
              span.step-label Car
            .step.is-active
              span.step-dot 2
              span.step-label Select work
            .step
              span.step-dot 3
              span.step-label Details
            .step
              span.step-dot 4
              span.step-label Book
        .work-type-layout-2(data-service-category=type)
          nav.work-tabs(aria-label="Service types")
            a.work-tab(class=(type === "repair" ? "is-active" : "") href="/bookings/work?type=repair") Repairs
            a.work-tab(class=(type === "diagnostics" ? "is-active" : "") href="/bookings/work?type=diagnostics") Diagnostics
            a.work-tab(class=(type === "service" ? "is-active" : "") href="/bookings/work?type=service") Servicing & MOT
            a.work-tab(class=(type === "tyres" ? "is-active" : "") href="/bookings/work?type=tyres") Tyres
            a.work-tab(class=(type === "inspection" ? "is-active" : "") href="/bookings/work?type=inspection") Pre-purchase inspections
          section.bookings-work
            if type === "diagnostics"
              h2 In-person diagnostic
              p Get a mechanic to diagnose the issue and give you a no-obligation quote for any required repairs.
              ul.work-list#serviceList
              p.form-error#serviceListEmpty No services found.
              p.work-hint
                | Unsure what's wrong with your car?
                a(href="#" aria-label="Use our free diagnostics tool") Use our free diagnostics tool.
            else if type === "service"
              h2 Servicing & MOT
              ul.work-list#serviceList
              p.form-error#serviceListEmpty No services found.
              .compare-table
                  .compare-header
                    span Compare
                    span Interim
                    span Full
                    span Major
                  .compare-row
                    span Number of checks
                    span 50
                    span 70
                    span 71
                  .compare-row
                    span Parts included
                    span
                    span
                    span
                  .compare-row
                    span Engine oil
                    span ✓
                    span ✓
                    span ✓
                  .compare-row
                    span Oil filter
                    span ✓
                    span ✓
                    span ✓
                  .compare-row
                    span Air filter
                    span ✕
                    span ✓
                    span ✓
                  .compare-row
                    span Pollen filter
                    span ✕
                    span ✕
                    span ✓
                  .compare-row
                    span Spark plugs
                    span ✕
