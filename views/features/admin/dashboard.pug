extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Admin"
  - var bodyClass = "admin-body app-shell-body"

block head
  link(rel="stylesheet", href="/css/features/dashboard/layout.css")
  link(rel="stylesheet", href="/css/features/admin/dashboard.css")

block content
  header.main-header.general-header
    .body-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace
      button.admin-header-menu-toggle#adminHeaderMobileMenuToggle(type="button" aria-label="Open menu" aria-expanded="false")
        span
        span
        span

  main.primari-shell
    .page-shell-content
      section.mainLayout#adminPage
        .admin-mobile-menu-backdrop#adminMobileMenuBackdrop
        aside.admin-mobile-menu#adminMobileMenu(aria-hidden="true")
          .admin-mobile-menu-head
            span.admin-mobile-name#adminMobileMenuName Admin
          nav.admin-mobile-menu-nav
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="dashboard") Dashboard
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="account") Account
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="bookings") Booking information
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="users") Users
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="applications") Applications
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="resolution") Resolution
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="payments") Payments
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="catalog") Catalog
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="contact-messages") Contact messages
            button.admin-mobile-menu-link.rail-nav-link(type="button" data-view="settings") Settings
          button.admin-mobile-signout#adminMobileLogoutBtn(type="button") Logout
        aside.mainRail.rail-base
          .rail-brand
            span.logo SW
          nav.rail-nav
            button.rail-nav-link.rail-item.active(type="button" data-view="dashboard")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M3 3h8v8H3z")
                  path(d="M13 3h8v5h-8z")
                  path(d="M13 10h8v11h-8z")
                  path(d="M3 13h8v8H3z")
              span.rail-text Dashboard
            button.rail-nav-link.rail-item(type="button" data-view="account")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  circle(cx="12" cy="8" r="4")
                  path(d="M5 20a7 7 0 0 1 14 0")
              span.rail-text Account
            button.rail-nav-link.rail-item(type="button" data-view="bookings")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M3 7h18")
                  path(d="M8 3v4")
                  path(d="M16 3v4")
                  rect(x="3" y="7" width="18" height="14" rx="2")
              span.rail-text Booking information
            button.rail-nav-link.rail-item(type="button" data-view="users")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2")
                  circle(cx="8.5" cy="7" r="4")
                  path(d="M20 8v6")
                  path(d="M23 11h-6")
              span.rail-text Users
            button.rail-nav-link.rail-item(type="button" data-view="applications")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M8 6h13")
                  path(d="M8 12h13")
                  path(d="M8 18h13")
                  path(d="M3 6h.01")
                  path(d="M3 12h.01")
                  path(d="M3 18h.01")
              span.rail-text Applications
            button.rail-nav-link.rail-item(type="button" data-view="resolution")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z")
              span.rail-text Resolution
            button.rail-nav-link.rail-item(type="button" data-view="payments")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  rect(x="2" y="5" width="20" height="14" rx="2")
                  path(d="M2 10h20")
              span.rail-text Payments
            button.rail-nav-link.rail-item(type="button" data-view="catalog")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20")
                  path(d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z")
              span.rail-text Catalog
            button.rail-nav-link.rail-item(type="button" data-view="contact-messages")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  path(d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H8l-4 4V8a2 2 0 0 1 2-2z")
                  path(d="m8 10 4 3 4-3")
              span.rail-text Contact messages
            button.rail-nav-link.rail-item(type="button" data-view="settings")
              span.rail-icon(aria-hidden="true")
                svg(viewBox="0 0 24 24")
                  circle(cx="12" cy="12" r="3")
                  path(d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-1.8-.3 1.6 1.6 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.2a1.6 1.6 0 0 0-1-1.5 1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 0 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0 .3-1.8 1.6 1.6 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.2a1.6 1.6 0 0 0 1.5-1 1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.6 1.6 0 0 0 1.8.3h.1a1.6 1.6 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.2a1.6 1.6 0 0 0 1 1.5h.1a1.6 1.6 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8v.1a1.6 1.6 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.2a1.6 1.6 0 0 0-1.5 1z")
              span.rail-text Settings
          .rail-footer
            button.admin-signout#adminLogoutBtn(type="button") Sign out

        section.mainSection
          .admin-dashboard-hero
            .settings-header
              .settings-header-copy
                h3#adminHeroSectionTitle Dashboard
                p#adminHeroSectionSubtitle General information
              .settings-header-aside
                .admin-dashboard-hero-copy
                  .admin-profile-avatar#adminDashboardHeroAvatar AU
                  div
                    h2 Welcome
                    p#adminDashboardHeroName Ramon Garcia
                    p#adminDashboardHeroRole ADMINISTRATOR
          p.admin-feedback.is-hidden#adminActionFeedback(role="alert" aria-live="polite")

          section.admin-content
            section.admin-view#adminDashboardView
              .admin-dashboard-layout
                .admin-panel
                  .admin-section-head
                    h3 Key metrics
                    p.admin-section-note-right Core platform numbers for today.
                  .admin-dashboard-metrics
                    .admin-dashboard-metric-card
                      span.label Bookings today
                      strong#adminMetricBookingsTodayCard 0
                      span Track new work created today.
                    .admin-dashboard-metric-card
                      span.label Open cases
                      strong#adminMetricOpenCasesCard 0
                      span Resolution cases still active.
                    .admin-dashboard-metric-card
                      span.label Pending applications
                      strong#adminMetricPendingApplicationsCard 0
                      span Mechanic applications needing review.
                    .admin-dashboard-metric-card
                      span.label Pending payouts
                      strong#adminMetricPendingPayoutsCard 0
                      span Payouts not finished yet.
                .settings-divider
                .admin-panel
                  .admin-panel-head
                    h3 Priority queues
                    p Focus on what needs action first.
                  .admin-dashboard-queues
                    .admin-queue-item
                      span.label Applications pending
                      strong#adminQueueApplications 0
                    .admin-queue-item
                      span.label Open complaints
                      strong#adminQueueResolution 0
                    .admin-queue-item
                      span.label Pending payouts
                      strong#adminQueuePayments 0
                    .admin-queue-item
                      span.label Bookings at risk
                      strong#adminQueueBookings 0
                .settings-divider
                .admin-panel
                  .admin-panel-head
                    h3 Recent bookings
                    p Latest bookings across the platform.
                  .admin-dashboard-list#adminDashboardRecentBookings
                .settings-divider
                .admin-panel
                  .admin-panel-head
                    h3 Recent applications
                    p New mechanic applications waiting in the queue.
                  .admin-dashboard-list#adminDashboardRecentApplications
                .settings-divider
                .admin-panel
                  .admin-panel-head
                    h3 Recent resolution cases
                    p Most recent active customer and mechanic issues.
                  .admin-dashboard-list#adminDashboardRecentCases
                .settings-divider
                .admin-panel
                  .admin-panel-head
                    h3 Contact messages
                    p Messages sent from the homepage contact form.
                  .admin-dashboard-list#adminDashboardContactMessages
                .settings-divider
                .admin-panel
                  .admin-panel-head
                    h3 Quick actions
                    p Jump directly to the admin areas that need attention.
                  .admin-dashboard-actions
                    button.ghost(type="button" data-admin-dashboard-target="applications") Review applications
                    button.ghost(type="button" data-admin-dashboard-target="resolution") Open cases
                    button.ghost(type="button" data-admin-dashboard-target="payments") Check payouts
                    button.ghost(type="button" data-admin-dashboard-target="users") Manage users

            section.admin-view.is-hidden#adminUsersView
              .admin-user-layout
                .admin-table-layout
                  .admin-table-head
                    .admin-table-head-filters
                      .admin-head-control.admin-head-control--search#adminSearchSection(data-filter-section)
                        span.admin-head-label.is-hidden#adminSearchLabel Search
                        input#adminSearch.side-input(type="search" placeholder="Search")
                      .admin-head-control.admin-head-control--role#adminRoleSection(data-filter-section)
                        span.admin-head-label.is-hidden#adminRoleLabel Role
                        select#adminRoleFilter.side-select(data-all-label="Role")
                          option(value="all") Role
                      .admin-head-control.admin-head-control--status#adminStatusSection(data-filter-section)
                        span.admin-head-label.is-hidden#adminStatusLabel Status
                        select#adminStatusFilter.side-select(data-all-label="Status")
                          option(value="all") Status
                      .admin-head-control.admin-head-control--date#adminDateSection(data-filter-section)
                        span.admin-head-label.is-hidden#adminDateLabel Date
                        select#adminDateFilter.side-select(data-all-label="Date")
                          option(value="all") Date
                    .admin-table-head-actions
                      span.is-hidden#adminUserCount 0
                      button.ghost#adminExportBtn(type="button")
                        svg.admin-button-icon(viewBox="0 0 24 24" aria-hidden="true")
                          path(d="M12 16V5")
                          path(d="m8 9 4-4 4 4")
                          path(d="M5 19h14")
                        span Export
                      button.primary#adminAddUserBtn(type="button") Add User
                  .admin-table-wrap
                    table.admin-table
                      thead
                        tr
                          th
                            input#adminUsersSelectAll(type="checkbox" aria-label="Select all users")
                          th.admin-sortable(data-sort-key="full_name")
                            button.admin-sort-button(type="button")
                              span Full name
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="email")
                            button.admin-sort-button(type="button")
                              span Email
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="username")
                            button.admin-sort-button(type="button")
                              span Username
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="status")
                            button.admin-sort-button(type="button")
                              span Status
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="role")
                            button.admin-sort-button(type="button")
                              span Role
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="experience")
                            button.admin-sort-button(type="button")
                              span Exp.
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="joined_date")
                            button.admin-sort-button(type="button")
                              span Joined date
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-sort-key="last_active")
                            button.admin-sort-button(type="button")
                              span Last active
                              span.admin-sort-icon(aria-hidden="true")
                          th
                      tbody#adminUserRows
                    p.admin-empty#adminEmptyState.is-hidden No users found.
                  .admin-table-footer
                    .admin-table-footer-meta
                      span Rows per page
                      select#adminRowsPerPage
                        option(value="10") 10
                        option(value="20") 20
                        option(value="50") 50
                      span#adminRowsMeta 0 of 0 rows
                    .admin-pagination#adminPagination

            section.admin-view.is-hidden#adminApplicationsView
              .admin-user-layout
                .admin-table-layout
                  .admin-table-head
                    .admin-table-head-filters
                      .admin-head-control.admin-head-control--search
                        span.admin-head-label.is-hidden Search
                        input#adminApplicationsSearch.side-input(type="search" placeholder="Search")
                      .admin-head-control.admin-head-control--role
                        span.admin-head-label.is-hidden Type
                        select#adminApplicationsTypeFilter.side-select(data-all-label="Type")
                          option(value="all") Type
                      .admin-head-control.admin-head-control--status
                        span.admin-head-label.is-hidden Status
                        select#adminApplicationsStatusFilter.side-select(data-all-label="Status")
                          option(value="all") Status
                      .admin-head-control.admin-head-control--date
                        span.admin-head-label.is-hidden Date
                        select#adminApplicationsDateFilter.side-select(data-all-label="Date")
                          option(value="all") Date
                    .admin-table-head-actions
                      span.is-hidden#adminApplicationsCount 0
                      button.ghost#adminApplicationsExportBtn(type="button")
                        svg.admin-button-icon(viewBox="0 0 24 24" aria-hidden="true")
                          path(d="M12 16V5")
                          path(d="m8 9 4-4 4 4")
                          path(d="M5 19h14")
                        span Export
                  .admin-table-wrap
                    table.admin-table
                      thead
                        tr
                          th.table-check
                            input#adminApplicationsSelectAll(type="checkbox" aria-label="Select all applications")
                          th.admin-sortable(data-app-sort-key="full_name")
                            button.admin-sort-button(type="button")
                              span Name
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-app-sort-key="application_type")
                            button.admin-sort-button(type="button")
                              span Type
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-app-sort-key="lead_postcode")
                            button.admin-sort-button(type="button")
                              span Postcode
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-app-sort-key="documents_count")
                            button.admin-sort-button(type="button")
                              span Docs
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-app-sort-key="application_status")
                            button.admin-sort-button(type="button")
                              span Status
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-app-sort-key="account_status")
                            button.admin-sort-button(type="button")
                              span Account status
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-app-sort-key="created_at")
                            button.admin-sort-button(type="button")
                              span Created
                              span.admin-sort-icon(aria-hidden="true")
                          th Actions
                      tbody#adminApplicationsRows
                    p.admin-empty#adminApplicationsEmptyState.is-hidden No mechanic applications found.
                  .admin-table-footer
                    .admin-table-footer-meta
                      span Rows per page
                      select#adminApplicationsRowsPerPage
                        option(value="10") 10
                        option(value="20") 20
                        option(value="50") 50
                      span#adminApplicationsRowsMeta 0 of 0 rows
                    .admin-pagination#adminApplicationsPagination
                  article.admin-application-detail-card.is-hidden#adminApplicationDetailCard
                    .admin-application-detail-card__head
                      div
                        span.admin-detail-eyebrow Application details
                        h3#adminApplicationDetailTitle Select an application
                      button.ghost#adminApplicationDetailClose(type="button") Close
                    .admin-application-detail-card__body#adminApplicationDetailBody

            section.admin-view.is-hidden#adminBookingsView
              .admin-user-layout
                .admin-table-layout
                  .admin-table-head
                    .admin-table-head-filters
                      .admin-head-control.admin-head-control--search
                        span.admin-head-label.is-hidden Search
                        input#adminBookingsSearch.side-input(type="search" placeholder="Search")
                      .admin-head-control.admin-head-control--role
                        span.admin-head-label.is-hidden Type
                        select#adminBookingsTypeFilter.side-select(data-all-label="Type")
                          option(value="all") Type
                      .admin-head-control.admin-head-control--status
                        span.admin-head-label.is-hidden Status
                        select#adminBookingsStatusFilter.side-select(data-all-label="Status")
                          option(value="all") Status
                      .admin-head-control.admin-head-control--date
                        span.admin-head-label.is-hidden Date
                        select#adminBookingsDateFilter.side-select(data-all-label="All time")
                          option(value="all") All time
                    .admin-table-head-actions
                      span.is-hidden#adminBookingsCount 0
                      button.ghost#adminBookingsExportBtn(type="button")
                        svg.admin-button-icon(viewBox="0 0 24 24" aria-hidden="true")
                          path(d="M12 16V5")
                          path(d="m8 9 4-4 4 4")
                          path(d="M5 19h14")
                        span Export
                  .admin-table-wrap
                    table.admin-table
                      thead
                        tr
                          th.table-check
                            input#adminBookingsSelectAll(type="checkbox" aria-label="Select all bookings")
                          th.admin-sortable(data-booking-sort-key="reference")
                            button.admin-sort-button(type="button")
                              span Reference
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="status")
                            button.admin-sort-button(type="button")
                              span Status
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="customer_name")
                            button.admin-sort-button(type="button")
                              span Customer
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="mechanic_name")
                            button.admin-sort-button(type="button")
                              span Mechanic
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="vehicle")
                            button.admin-sort-button(type="button")
                              span Vehicle
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="location")
                            button.admin-sort-button(type="button")
                              span Location
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="total")
                            button.admin-sort-button(type="button")
                              span Total
                              span.admin-sort-icon(aria-hidden="true")
                          th.admin-sortable(data-booking-sort-key="created_at")
                            button.admin-sort-button(type="button")
                              span Created
                              span.admin-sort-icon(aria-hidden="true")
                          th Actions
                      tbody#adminBookingsRows
                    p.admin-empty#adminBookingsEmptyState.is-hidden No bookings found.
                  .admin-table-footer
                    .admin-table-footer-meta
                      span Rows per page
                      select#adminBookingsRowsPerPage
                        option(value="10") 10
                        option(value="20") 20
                        option(value="50") 50
                      span#adminBookingsRowsMeta 0 of 0 rows
                    .admin-pagination#adminBookingsPagination
                  article.admin-booking-detail-card.is-hidden#adminBookingsDetailCard
                    .admin-booking-detail-card__head
                      .admin-booking-detail-copy
                        span.admin-detail-eyebrow Booking details
                        h3#adminBookingsDetailTitle Booking details
                      button.ghost#adminBookingsDetailClose(type="button") Close
                    .admin-booking-detail-grid#adminBookingsDetailBody

            section.admin-view.is-hidden#adminResolutionView
              .admin-user-layout
                .admin-table-layout
                  .admin-table-head
                    .admin-table-head-filters
                      .admin-head-control.admin-head-control--search
                        span.admin-head-label.is-hidden Search
                        input#adminResolutionSearch.side-input(type="search" placeholder="Search")
                      .admin-head-control.admin-head-control--role
                        span.admin-head-label.is-hidden Type
                        select#adminResolutionTypeFilter.side-select(data-all-label="Type")
                          option(value="all") Type
                      .admin-head-control.admin-head-control--status
                        span.admin-head-label.is-hidden Status
                        select#adminResolutionStatusFilter.side-select(data-all-label="Status")
                          option(value="all") Status
                      .admin-head-control.admin-head-control--date
                        span.admin-head-label.is-hidden Date
                        select#adminResolutionDateFilter.side-select(data-all-label="All time")
                          option(value="all") All time
                    .admin-table-head-actions
                      span.is-hidden#adminResolutionCount 0
                      button.ghost#adminResolutionExportBtn(type="button")
                        svg.admin-button-icon(viewBox="0 0 24 24" aria-hidden="true")
                          path(d="M12 16V5")
                          path(d="m8 9 4-4 4 4")
                          path(d="M5 19h14")
                        span Export
                  .admin-table-wrap
                    table.admin-table
                      thead
                        tr
                          th.table-check
                            input#adminResolutionSelectAll(type="checkbox" aria-label="Select all resolution cases")
                          th Payment number
                          th Type
                          th Subject
                          th Status
                          th Customer
                          th Mechanic
                          th Updated
                          th Actions
                      tbody#adminResolutionRows
                    p.admin-empty#adminResolutionEmptyState.is-hidden No resolution cases found.
                  .admin-table-footer
                    .admin-table-footer-meta
                      span Rows per page
                      select#adminResolutionRowsPerPage
                        option(value="10") 10
                        option(value="20") 20
                        option(value="50") 50
                      span#adminResolutionRowsMeta 0 of 0 rows
                    .admin-pagination#adminResolutionPagination
                  article.admin-resolution-detail-card.is-hidden#adminResolutionDetailCard
                    .admin-resolution-detail-card__head
                      div
                        span.admin-detail-eyebrow Resolution case
                        h3#adminResolutionDetailTitle Select a case
                      button.ghost#adminResolutionDetailClose(type="button") Close
                    .admin-resolution-detail-card__body#adminResolutionDetailBody

            section.admin-view.is-hidden#adminPaymentsView
              .admin-user-layout
                .admin-table-layout
                  .admin-table-head
                    .admin-table-head-filters
                      .admin-head-control.admin-head-control--search
                        span.admin-head-label.is-hidden Search
                        input#adminPaymentsSearch.side-input(type="search" placeholder="Search")
                      .admin-head-control.admin-head-control--role
                        span.admin-head-label.is-hidden Type of payment
                        select#adminPaymentsKindFilter.side-select(data-all-label="Type of payment")
                          option(value="all") Type of payment
                      .admin-head-control.admin-head-control--status
                        span.admin-head-label.is-hidden Status
                        select#adminPaymentsStatusFilter.side-select(data-all-label="Status")
                          option(value="all") Status
                      .admin-head-control.admin-head-control--date
                        span.admin-head-label.is-hidden Date
                        select#adminPaymentsDateFilter.side-select(data-all-label="All time")
                          option(value="all") All time
                    .admin-table-head-actions
                      span.is-hidden#adminPaymentsCount 0
                      button.ghost#adminPaymentsExportBtn(type="button")
                        svg.admin-button-icon(viewBox="0 0 24 24" aria-hidden="true")
                          path(d="M12 16V5")
                          path(d="m8 9 4-4 4 4")
                          path(d="M5 19h14")
                        span Export
                  .admin-table-wrap
                    table.admin-table
                      thead
                        tr
                          th.table-check
                            input#adminPaymentsSelectAll(type="checkbox" aria-label="Select all payments")
                          th Payment number
                          th Type of payment
                          th Booking
                          th Provider
