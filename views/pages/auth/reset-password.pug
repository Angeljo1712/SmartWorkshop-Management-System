extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Set New Password"
  - var bodyClass = "auth-body"

block content
  main.auth-shell
    section.auth-card#resetPasswordPage
      h1 Set a new password
      p.muted Minimum 10 chars, 1 uppercase, 1 number, 1 symbol.
      form.auth-form#resetPasswordForm
        label
          | New password
          input#resetPasswordValue(type="password" placeholder="••••••••" autocomplete="new-password")
        label
          | Confirm password
          input#resetPasswordConfirm(type="password" placeholder="••••••••" autocomplete="new-password")
        p.form-error#resetPasswordError(role="alert" aria-live="polite")
        button.primary.auth-submit(type="submit") Update password
      p.auth-footnote
        a(href="/auth/login") Back to sign in
