extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Admin"
  - var bodyClass = "admin-body"

block content
  main.admin-shell.admin-ui#adminPage
    section.admin-gate#adminGate
      .admin-gate-card
        h2 Admins only
        p Sign in with an administrator account to access user management.
        p.form-error#adminLoginError(role="alert" aria-live="polite")
        a.ghost-link(href="/auth/login")
          button.primary(type="button") Go to Sign in

    section.admin-app.is-hidden#adminApp
      aside.admin-rail
        .rail-brand
          span.logo SW
        nav.rail-nav
          button.admin-nav-link.rail-item.active(type="button" data-view="users")
            span.rail-icon(aria-hidden="true")
              svg(viewBox="0 0 24 24")
                path(d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2")
                circle(cx="8.5" cy="7" r="4")
                path(d="M20 8v6")
                path(d="M23 11h-6")
            | Users
          button.admin-nav-link.rail-item(type="button" data-view="profile")
            span.rail-icon(aria-hidden="true")
              svg(viewBox="0 0 24 24")
                circle(cx="12" cy="8" r="4")
                path(d="M5 20a7 7 0 0 1 14 0")
            | Profile
          button.admin-nav-link.rail-item(type="button" data-view="settings")
            span.rail-icon(aria-hidden="true")
              svg(viewBox="0 0 24 24")
                circle(cx="12" cy="12" r="3")
                path(d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-1.8-.3 1.6 1.6 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.2a1.6 1.6 0 0 0-1-1.5 1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 0 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0 .3-1.8 1.6 1.6 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.2a1.6 1.6 0 0 0 1.5-1 1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.6 1.6 0 0 0 1.8.3h.1a1.6 1.6 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.2a1.6 1.6 0 0 0 1 1.5h.1a1.6 1.6 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8v.1a1.6 1.6 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.2a1.6 1.6 0 0 0-1.5 1z")
            | Settings
        .rail-footer
          button.admin-signout#adminLogoutBtn(type="button") Sign out

      aside.admin-side
        .side-card
          .side-title Filters
          .side-section(data-filter-section)
            .side-section-head
              label.side-label Job title
              button.filter-toggle(type="button" aria-expanded="true" aria-label="Toggle Job title filter")
                svg(viewBox="0 0 24 24" aria-hidden="true")
                  path(d="M6 9l6 6 6-6")
            .side-section-body
              input.side-input(type="text" placeholder="Search job titles")
          .side-section(data-filter-section)
            .side-section-head
              label.side-label Role
              button.filter-toggle(type="button" aria-expanded="true" aria-label="Toggle Role filter")
                svg(viewBox="0 0 24 24" aria-hidden="true")
                  path(d="M6 9l6 6 6-6")
            .side-section-body
              select#adminRoleFilter.side-select
                option(value="all") All
                option(value="ADMIN") Admin
                option(value="MECHANIC") Mechanic
                option(value="CUSTOMER") Customer
          .side-section(data-filter-section)
            .side-section-head
              label.side-label Status
              button.filter-toggle(type="button" aria-expanded="true" aria-label="Toggle Status filter")
                svg(viewBox="0 0 24 24" aria-hidden="true")
                  path(d="M6 9l6 6 6-6")
            .side-section-body
              select#adminStatusFilter.side-select
                option(value="all") All
                option(value="Active") Active
                option(value="Pending") Pending
                option(value="Suspended") Suspended
                option(value="Banned") Banned
          .side-section(data-filter-section)
            .side-section-head
              label.side-label Date
              button.filter-toggle(type="button" aria-expanded="true" aria-label="Toggle Date filter")
                svg(viewBox="0 0 24 24" aria-hidden="true")
                  path(d="M6 9l6 6 6-6")
            .side-section-body
              select#adminDateFilter.side-select
                option(value="all") All time
                option(value="30") Last 30 days
                option(value="90") Last 90 days
                option(value="365") Last year

      section.admin-main
        section.admin-view#adminUsersView
          .admin-table-card
            .admin-table-head
              .head-left
                h3 Users
                p
                  span#adminUserCount 0
              .admin-table-actions
                input#adminSearch.side-input(type="search" placeholder="Search")
                select#adminRowsPerPage
                  option(value="10") 10 rows
                  option(value="20") 20 rows
                  option(value="50") 50 rows

            .admin-table-wrap
              table.admin-table
                thead
                  tr
                    th
                    th Name
                    th Location
                    th Current Job
                    th Exp.
                    th Ready
                    th Score
                    th
                tbody#adminUserRows
              p.admin-empty#adminEmptyState.is-hidden No users found.

            .admin-table-footer
              span#adminRowsMeta 0 of 0 rows
              .admin-pagination#adminPagination

        section.admin-view.is-hidden#adminProfileView
          .admin-profile-card
            .profile-left
              .admin-profile-avatar#adminProfileAvatar AU
              div
                strong#adminProfileName Admin User
                span#adminProfileRole Administrator
            .profile-right
              .profile-item.is-hidden
                span.label Avatar
                span#adminSettingsAvatar AU
              .profile-item.is-hidden
                span.label Name
                span#adminSettingsName Admin User
              .profile-item
                span.label Email
                span#adminSettingsEmail admin@smartworkshop.local
              .profile-item.is-hidden
                span.label Email detail
                span#adminSettingsEmailDetail Email: admin@smartworkshop.local
              .profile-item
                span.label Phone
                span#adminSettingsPhone Phone: -
              .profile-item
                span.label Role
                span#adminSettingsRole Administrator

        section.admin-view.is-hidden#adminSettingsView
          .admin-profile-card
            .profile-left
              .admin-profile-avatar AA
              div
                strong Admin Settings
                span Manage your workspace preferences
            .profile-right
              .profile-item
                span.label Theme
                span Dark
              .profile-item
                span.label Notifications
                span Enabled
              .profile-item
                span.label Access
                span Administrator

        section.admin-panel.is-hidden#adminAddUserPanel
          .admin-panel-head
            h3 New user
            button.ghost#adminAddUserClose(type="button") Close
          form.admin-form#adminAddUserForm
            .admin-form-row
              label
                | Full name
                input#adminNewName(type="text" placeholder="Jane Mechanic" required)
              label
                | Email
                input#adminNewEmail(type="email" placeholder="jane@shop.co.uk" required)
            .admin-form-row
              label
                | Role
                select#adminNewRole
                  option(value="ADMIN") Admin
                  option(value="MECHANIC") Mechanic
                  option(value="CUSTOMER") Customer
              label
                | Temporary password
                input#adminNewPassword(type="password" placeholder="Temp password" required)
            p.form-error#adminAddUserError(role="alert" aria-live="polite")
            button.primary(type="submit") Create user
