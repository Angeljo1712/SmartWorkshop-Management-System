extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Bookings"
  - var bodyClass = ""

block content
  include ../../partials/navbar
  main.page-shell.bookings-shell
    .bookings-hero
      .stepper(aria-label="Booking steps")
        .step.is-complete
          span.step-dot 1
          span.step-label Car
        .step.is-active
          span.step-dot 2
          span.step-label Select work
        .step
          span.step-dot 3
          span.step-label Details
        .step
          span.step-dot 4
          span.step-label Book

      .bookings-headline
        h1#bookingsTitle What does your vehicle need?
        p#bookingsSubtitle You're just seconds away from getting a fixed price quote for your car.

    section.bookings-grid(aria-label="Service categories")
      a.bookings-card-link(href="/bookings/work/?type=repair" aria-label="Repairs")
        article.bookings-card
          .bookings-icon(aria-hidden="true")
            svg(viewBox="0 0 24 24" role="img")
              path(d="M7 8l2-2 2 2-2 2-2-2zm8 8l2-2 2 2-2 2-2-2zM4 20l5-5 3 3-5 5H4v-3zm10-10l3-3 3 3-3 3-3-3z")
          h3 Repairs
          p Know what's wrong? Book in the repair you need.
      a.bookings-card-link(href="/bookings/work/?type=diagnostics" aria-label="Diagnostics")
        article.bookings-card
          .bookings-icon(aria-hidden="true")
            svg(viewBox="0 0 24 24" role="img")
              path(d="M4 6h16v10H4V6zm2 2v6h12V8H6zm-2 10h16v2H4v-2z")
          h3 Diagnostics
          p Unsure what's wrong? Have a mechanic identify the problem.
      a.bookings-card-link(href="/bookings/work/?type=service" aria-label="Servicing and MOT")
        article.bookings-card
          .bookings-icon(aria-hidden="true")
            svg(viewBox="0 0 24 24" role="img")
              path(d="M8 3h8l1 4H7l1-4zm-2 6h12v12H6V9zm2 2v8h8v-8H8z")
          h3 Servicing & MOT
          p Keep your vehicle safe and in top condition.
      a.bookings-card-link(href="/bookings/work/?type=tyres" aria-label="Tyres")
        article.bookings-card
          .bookings-icon(aria-hidden="true")
            svg(viewBox="0 0 24 24" role="img")
              path(d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 3l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4l2-4z")
          h3 Tyres
          p Need a tyre replacement? Book with us online.
      a.bookings-card-link(href="/bookings/work/?type=inspection" aria-label="Pre-purchase inspections")
        article.bookings-card
          .bookings-icon(aria-hidden="true")
            svg(viewBox="0 0 24 24" role="img")
              path(d="M6 7h12l2 5v7H4v-7l2-5zm2 2l-1 3v5h10v-5l-1-3H8zm2 6h4v2h-4v-2z")
          h3 Pre-purchase inspections
          p Buying a used car? Have a mechanic check it for you.

