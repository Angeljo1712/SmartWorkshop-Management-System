            li.work-row
              .work-main
                strong Plug-in diagnostic inspection
                .work-price £66.39
                .work-rating
                  span.rating-stars ★★★★★
                  span 4113 reviews
              .work-actions
                a(href="#" aria-label="More info about plug-in diagnostic inspection") More info
                button.primary(type="button") Add
          p.work-hint
            | Unsure what's wrong with your car?
            a(href="#" aria-label="Use our free diagnostics tool") Use our free diagnostics tool.
        else if type === "service"
