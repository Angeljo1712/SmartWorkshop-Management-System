extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Bookings"
  - var bodyClass = "bookings-body"

block head
  link(rel="stylesheet", href="/css/pages/bookings.css")

block content
  header.main-header.general-header
    .header-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace
  main.page-shell.bookings-shell
    nav.work-tabs(aria-label="Service types")
      a.work-tab(class=(type === "repair" ? "is-active" : "") href="/bookings/work?type=repair") Repairs
      a.work-tab(class=(type === "diagnostics" ? "is-active" : "") href="/bookings/work?type=diagnostics") Diagnostics
      a.work-tab(class=(type === "service" ? "is-active" : "") href="/bookings/work?type=service") Servicing & MOT
      a.work-tab(class=(type === "tyres" ? "is-active" : "") href="/bookings/work?type=tyres") Tyres
      a.work-tab(class=(type === "inspection" ? "is-active" : "") href="/bookings/work?type=inspection") Pre-purchase inspections
    .work-layout(data-service-category=type)
      section.bookings-work
        if type === "diagnostics"
          h2 In-person diagnostic
          p Get a mechanic to diagnose the issue and give you a no-obligation quote for any required repairs.
          ul.work-list#serviceList
          p.form-error#serviceListEmpty No services found.
          p.work-hint
            | Unsure what's wrong with your car?
            a(href="#" aria-label="Use our free diagnostics tool") Use our free diagnostics tool.
        else if type === "service"
          h2 Servicing & MOT
          ul.work-list#serviceList
          p.form-error#serviceListEmpty No services found.
          .compare-table
            .compare-header
              span Compare
              span Interim
              span Full
              span Major
            .compare-row
              span Number of checks
              span 50
              span 70
              span 71
