extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Booking Confirmed"
  - var bodyClass = "bookings-body app-shell-body"

block head
  link(rel="stylesheet", href="/css/pages/bookings.css")

block content
  header.main-header.basic-header
    .body-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace
      a.bookings-header-help(href="#") Need help?
  main.primari-shell#bookingConfirmPage
    .page-shell-content
      .confirm-layout1
        .bookings-stepper
          .stepper.stepper--progress-4(aria-label="Booking steps")
            .step.is-complete
              span.step-dot 1
              span.step-label Car
            .step.is-complete
              span.step-dot 2
              span.step-label Select work
            .step.is-complete
              span.step-dot 3
              span.step-label Details
            .step.is-complete
              span.step-dot 4
              span.step-label Book
        .confirm-layout2
          aside.details-summary
            .price-card
              .price-head
                span Total price
                span.save-badge Paid
              .price-main
                span.price-value#confirmTotal £0.00
                span.price-note Payment completed
            .summary-section
              h3 Selected work
              p.form-error.is-hidden#confirmEmpty No items selected yet.
              #confirmItems
          section.details-content
            h1 Booking confirmed
            .details-card
              h3 Booking reference
              p#confirmBookingReference -
            .details-card
              h3 Customer details
              p#confirmCustomerName -
              p#confirmCustomerEmail -
              p#confirmCustomerPhone -
            .details-card
              h3 Address
              p#confirmAddress -
            .details-card
              h3 Vehicle availability
              p#confirmAvailability -
            .details-card
              h3 Vehicle collection
              p#confirmVehicleDrivable -
            .details-card
              h3 Diagnostic inspection notes
              p#confirmDiagnosticNotes -
            .details-card.is-hidden#confirmAccountCard
              h3 Create your account password
              p.help-text Set a password now so you can sign in as a customer and manage your booking.
              label
                | Password
                input#confirmAccountPassword(type="password")
              label
                | Confirm password
                input#confirmAccountPasswordConfirm(type="password")
              p.form-error#confirmAccountError(role="alert" aria-live="polite")
              button.primary#confirmAccountSubmit(type="button") Create account access
  include ../../partials/general-footer

