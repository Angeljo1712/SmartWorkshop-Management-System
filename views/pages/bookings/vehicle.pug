extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Vehicle"
  - var bodyClass = "bookings-body"

block head
  link(rel="stylesheet", href="/css/pages/bookings.css")

block content
  header.main-header.booking-header
    .body-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace
      a.bookings-header-help(href="#") Need help?
  main.primari-shell
    .page-shell-content
      .bookings-layout.bookings-layout--vehicle
        .bookings-stepper
          .stepper.stepper--progress-0(aria-label="Booking steps")
            .step.is-active
              span.step-dot 1
              span.step-label Car
            .step
              span.step-dot 2
              span.step-label Select work
            .step
              span.step-dot 3
              span.step-label Details
            .step
              span.step-dot 4
              span.step-label Book

        .bookings-headline
          h1 Tell us about your car
          p You're just seconds away from getting a fixed price quote for your car.

        section.bookings-vehicle-card(aria-label="Vehicle details")
          .bookings-vehicle-tabs(aria-label="Vehicle lookup method")
            span.bookings-vehicle-tab.is-active Use number plate
          form.bookings-vehicle-form#vehicleLookupForm
            label.bookings-vehicle-field
              span.bookings-vehicle-field-head
                span.bookings-vehicle-field-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    path(d="M6 8.5h12l1.5 4v4h-1.5a1.5 1.5 0 0 1-3 0H9a1.5 1.5 0 0 1-3 0H4.5v-4l1.5-4Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                    path(d="M8 8.5 9.2 5.5h5.6L16 8.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                    circle(cx="8" cy="16.5" r="1.1" fill="currentColor" stroke="none")
                    circle(cx="16" cy="16.5" r="1.1" fill="currentColor" stroke="none")
                span.bookings-vehicle-field-label Vehicle registration
              input#vehicleReg(name="vehicleReg" type="text" placeholder="KL05USC" autocomplete="off")
            label.bookings-vehicle-field
              span.bookings-vehicle-field-head
                span.bookings-vehicle-field-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24" role="img")
                    path(d="M12 21s6-5.9 6-11a6 6 0 1 0-12 0c0 5.1 6 11 6 11Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                    circle(cx="12" cy="10" r="2.5" fill="none" stroke="currentColor" stroke-width="1.8")
                span.bookings-vehicle-field-label Postcode
              input#postcode(name="postcode" type="text" placeholder="KT10 0QR" autocomplete="postal-code")
            p.form-error#vehicleLookupError(role="alert" aria-live="polite")
            button.primary.bookings-vehicle-submit(type="submit") Next step
  include ../../partials/general-footer
