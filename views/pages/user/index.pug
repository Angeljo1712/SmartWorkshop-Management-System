extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - User"
  - var bodyClass = "user-body app-shell-body"

block head
  link(rel="stylesheet", href="/css/pages/dashboard-layout.css")
  link(rel="stylesheet", href="/css/pages/user.css-dashboard.css")

block content
  header.main-header.general-header
    .body-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace

  main.primari-shell#userPage
    .page-shell-content
      section.user-layout.Layer1
          aside.user-rail.Layer2
            .rail-brand
              span.logo SW
            nav.rail-nav
              button.admin-nav-link.rail-item.user-nav-link.active(type="button" data-view="dashboard")
                span.rail-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24")
                    rect(x="3" y="3" width="8" height="8" rx="1")
                    rect(x="13" y="3" width="8" height="5" rx="1")
                    rect(x="13" y="10" width="8" height="11" rx="1")
                    rect(x="3" y="13" width="8" height="8" rx="1")
                | Dashboard
              button.admin-nav-link.rail-item.user-nav-link(type="button" data-view="account")
                span.rail-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24")
                    circle(cx="12" cy="8" r="4")
                    path(d="M5 20a7 7 0 0 1 14 0")
                | Account
              button.admin-nav-link.rail-item.user-nav-link(type="button" data-view="vehicle")
                span.rail-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24")
                    path(d="M5 16l1.5-5A2 2 0 0 1 8.4 9h7.2a2 2 0 0 1 1.9 2l1.5 5")
                    path(d="M4 16h16v3a1 1 0 0 1-1 1h-1v-2H6v2H5a1 1 0 0 1-1-1z")
                    circle(cx="7.5" cy="16.5" r="1")
                    circle(cx="16.5" cy="16.5" r="1")
                | Vehicle
              button.admin-nav-link.rail-item.user-nav-link(type="button" data-view="bookings")
                span.rail-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24")
                    path(d="M3 7h18")
                    path(d="M8 3v4")
                    path(d="M16 3v4")
                    rect(x="3" y="7" width="18" height="14" rx="2")
                | Bookings
              button.admin-nav-link.rail-item.user-nav-link(type="button" data-view="resolution")
                span.rail-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24")
                    circle(cx="12" cy="8" r="4")
                    path(d="M5 20a7 7 0 0 1 14 0")
                | Resolution center
              button.admin-nav-link.rail-item.user-nav-link(type="button" data-view="settings")
                span.rail-icon(aria-hidden="true")
                  svg(viewBox="0 0 24 24")
                    circle(cx="12" cy="12" r="3")
                    path(d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-1.8-.3 1.6 1.6 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.2a1.6 1.6 0 0 0-1-1.5 1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 0 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0 .3-1.8 1.6 1.6 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.2a1.6 1.6 0 0 0 1.5-1 1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.6 1.6 0 0 0 1.8.3h.1a1.6 1.6 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.2a1.6 1.6 0 0 0 1 1.5h.1a1.6 1.6 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8v.1a1.6 1.6 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.2a1.6 1.6 0 0 0-1.5 1z")
                | Settings
            .rail-footer
              button.admin-signout#userLogoutBtn(type="button") Sign out

          .is-hidden
            .admin-profile-avatar#userProfileAvatar AG
            strong#userProfileName Angel Gomes
            span#userProfileRole ADMIN
            select#userRoleSwitcher.role-switcher

          .user-content.Layer2
            section.user-view#userDashboardView
              .settings-card.user-dashboard-card
                .user-dashboard-layout
                  .dashboard-section.dashboard-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p#userDashboardName.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Dashboard
                        p.user-welcome-corner-subtitle General information

                  .settings-divider

                  .dashboard-section.dashboard-section--cars-header
                    .settings-header
                      div
                        h2 Your Cars
                        p Save up to 100 vehicles in your account.

                  .dashboard-section.dashboard-section--cars-list
                    .user-car-list#userCarList
                      .user-car-summary
                        .user-car-top
                          span.user-reg-badge KL05USC
                          strong COROLLA COLOUR COL-N VVTI
                        .user-car-meta
                          span Petrol
                          span 21 years old
                          span 39,580 miles
                        .user-car-status
                          p Your MOT is valid · Due in 28 weeks
                          p Taxed · Due in 24 weeks

                  .settings-divider

                  .dashboard-section.dashboard-section--add-title
                    h3.user-section-title Add another vehicle

                  .dashboard-section.dashboard-section--add-form
                    .user-add-vehicle
                      input#userDashboardCarReg(type="text" placeholder="Enter Car Reg")
                      button.primary#userAddVehicleBtn(type="button") Add Vehicle
                    p.form-error#userDashboardCarError(role="alert" aria-live="polite")

                  .dashboard-section.dashboard-section--quote
                    .user-quick-quote
                      label
                        | Vehicle Registration
                        input#userQuickQuoteReg(type="text" value="")
                      label
                        | Postcode
                        input(type="text" placeholder="Enter Your Postcode")
                      label
                        | Products
                        select#userQuickQuoteProduct
                          option(value="" selected) Select a product
                          option(value="repair") Repairs
                          option(value="diagnostics") Diagnostics
                          option(value="service") Servicing & MOT
                          option(value="tyres") Tyres
                          option(value="inspection") Pre-purchase inspections
                      button.primary#userQuickQuoteBtn(type="button") Compare Prices Instantly

            section.user-view.is-hidden#userAccountView
              .settings-card.user-account-card
                .user-account-layout
                  .dashboard-section.dashboard-section--welcome.account-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Account Details
                        p.user-welcome-corner-subtitle Review your profile information.

                  .settings-divider

                  .account-section.account-section--avatar
                    .settings-photo-row
                      .settings-avatar.settings-avatar-lg#userSettingsAvatar AG

                  .settings-divider

                  .account-section.account-section--profile
                    .settings-profile
                      .settings-meta
                        h4 Full Name
                        p#userSettingsName Angel Gomes
                        span#userSettingsRoleBadge.is-hidden CUSTOMER

                  .settings-divider

                  .account-section.account-section--contacts
                    div
                      h4 Contacts
                      p#userSettingsPhone Phone: -
                      p#userSettingsEmailDetail Email: admin@smartworkshop.local
                      p#userSettingsUsername Username: -
                      p#userSettingsAddress Address: -

                  .settings-divider

                  .account-section.account-section--role
                    div
                      h4 Role
                      p#userSettingsRole ADMIN

                  .settings-divider

                  .account-section.account-section--integration
                    div
                      h4 Integration
                      p No integrations connected


            section.user-view.is-hidden#userVehicleView
              .settings-card.user-vehicle-card
                .user-vehicle-layout
                  .dashboard-section.dashboard-section--welcome.vehicle-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Vehicle
                        p.user-welcome-corner-subtitle Information related to your vehicles

                  .settings-divider

                  .user-vehicle-heading
                    .user-vehicle-heading-top
                      button#userVehicleTitle.user-vehicle-title-button(type="button" aria-label="Select vehicle") RENAULT CLIO RENAULTSPORT NAV TROPHY A
                      span.user-reg-badge#userVehicleRegBadge BP67XRZ
                      button#userVehicleDropdownBtn.user-vehicle-dropdown-btn(type="button" aria-label="Open vehicle list")
                    .user-vehicle-dropdown-menu.is-hidden#userVehicleDropdownMenu

                  .user-vehicle-pills
                    span#userVehicleFuel Pill Petrol
                    span#userVehicleAge Pill 8 years old
                    span#userVehicleMileage Pill 13,126 miles

                  .user-vehicle-cards
                    .user-vehicle-info-card.is-mot
                      .user-vehicle-info-icon △
                      .user-vehicle-info-copy
                        strong Your MOT is valid
                        p#userVehicleMotStatus Due in 6 months
                      .user-vehicle-info-arrow ›
                    .user-vehicle-info-card.is-tax
                      .user-vehicle-info-icon ✓
                      .user-vehicle-info-copy
                        strong Your Tax is valid
                        p#userVehicleTaxStatus Due in 8 months
                      .user-vehicle-info-arrow ›
                    .user-vehicle-info-card.is-mileage
                      .user-vehicle-info-icon ⦿
                      .user-vehicle-info-copy
                        strong Mileage at last MOT
                        p#userVehicleMileageStatus 13,126 miles
                      .user-vehicle-info-arrow ›
                    .user-vehicle-info-card.is-details
                      .user-vehicle-info-icon car
                      .user-vehicle-info-copy
                        strong Vehicle Details
                        p View your vehicle's information
                      .user-vehicle-info-arrow ›

            section.user-view.is-hidden#userBookingsView
              .settings-card.user-bookings-card
                .user-bookings-layout
                  .dashboard-section.dashboard-section--welcome.bookings-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Your bookings
                        p.user-welcome-corner-subtitle Review of your bookings

                  .settings-divider.bookings-section--divider

                  .bookings-section.bookings-section--card
                    #userBookingsList.user-bookings-list

            section.user-view.is-hidden#userResolutionView
              .settings-card.user-resolution-card#userResolutionOverview
                .user-resolution-layout
                  .dashboard-section.dashboard-section--welcome.resolution-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Resolution center
                        p.user-welcome-corner-subtitle Manage mechanic issues and active resolutions.

                  .settings-divider.resolution-section--divider

                  .resolution-section.resolution-section--card
                    .mechanic-resolution-layout
                      .mechanic-resolution-card
                        h3 Current cases
                        .mechanic-resolution-card-body
                          .mechanic-resolution-tabs
                            button.mechanic-resolution-tab.is-active(type="button" data-user-resolution-filter="all") All
                            button.mechanic-resolution-tab(type="button" data-user-resolution-filter="complaint") Complaint
                            button.mechanic-resolution-tab(type="button" data-user-resolution-filter="general") General
                          .mechanic-resolution-table
                            .mechanic-resolution-table-head
                              span Status
                              span Reference
                              span Updated at
                              span Subject
                              span
                            #userResolutionCasesTable
              .settings-card.user-resolution-card.is-hidden#userResolutionMessageView
                .user-resolution-layout
                  .dashboard-section.dashboard-section--welcome.resolution-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Resolution center
                        p.user-welcome-corner-subtitle Manage mechanic issues and active resolutions.

                  .settings-divider.resolution-section--divider

                  .resolution-section.resolution-section--card
                    .mechanic-resolution-detail
                      .mechanic-resolution-detail-head
                        button.mechanic-resolution-back#userResolutionBackBtn(type="button") Back
                        h3#userResolutionDetailTitle Message mechanic regarding booking
                      .mechanic-resolution-card
                        .mechanic-resolution-field
                          label(for="userResolutionIssue") Please select your issue from the list below:
                          select#userResolutionIssue
                            option(value="message_mechanic" data-case-type="general" selected) Message my mechanic
                            option(value="mechanic_late" data-case-type="complaint") My mechanic is late
                            option(value="workmanship_problem" data-case-type="complaint") Problem with workmanship
                            option(value="charged_more_than_agreed" data-case-type="complaint") I've been charged more than agreed
                            option(value="charged_for_unagreed_work" data-case-type="complaint") I've been charged for work that I didn't agree to
                            option(value="mechanic_cancelled" data-case-type="complaint") Mechanic has cancelled my booking
                            option(value="other_problem" data-case-type="complaint") Other problem
                        p.mechanic-resolution-notice#userResolutionNotice No case has been created for this booking yet.
                        button.primary#userResolutionGoToCase(type="button") Go to case
                        .mechanic-resolution-complaint.is-hidden#userResolutionComplaintComposer
                          p.mechanic-resolution-complaint-copy#userResolutionComplaintCopy
                          textarea#userResolutionComplaintInput(rows="5" placeholder="Write your message here")
                          .mechanic-resolution-complaint-actions
                            button.primary#userResolutionComplaintSendBtn(type="button") Send
                          .mechanic-resolution-complaint-footer
                            button.secondary#userResolutionComplaintAttachBtn(type="button") Attach file(s)
                      .mechanic-resolution-card
                        .mechanic-resolution-card-header#userResolutionCaseListTitle Resolution cases already created for booking
                        .mechanic-resolution-table
                          .mechanic-resolution-table-head
                            span Status
                            span Reference
                            span Updated at
                            span Subject
                            span
                          #userResolutionBookingCasesTable

              .settings-card.user-resolution-card.is-hidden#userResolutionCaseView
                .user-resolution-layout
                  .dashboard-section.dashboard-section--welcome.resolution-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Resolution center
                        p.user-welcome-corner-subtitle Manage mechanic issues and active resolutions.

                  .settings-divider.resolution-section--divider

                  .resolution-section.resolution-section--card
                    .mechanic-resolution-case-view
                      .mechanic-resolution-case
                        .mechanic-resolution-detail-head
                          button.mechanic-resolution-back#userResolutionCaseBackBtn(type="button") Back
                          h3#userResolutionCaseTitle General Enquiry
                        .mechanic-resolution-thread#userResolutionMessages
                        .mechanic-resolution-compose
                          textarea#userResolutionMessageInput(rows="5" placeholder="Add a new message here")
                          .mechanic-resolution-compose-actions
                            button.primary#userResolutionSendBtn(type="button") Send message
                      aside.mechanic-resolution-sidebar
                        .mechanic-resolution-sidebar-card
                          h4#userResolutionSidebarTitle Current status of booking
                          .mechanic-resolution-sidebar-row
                            strong Mechanic
                            span#userResolutionSidebarMechanic -
                          .mechanic-resolution-sidebar-row
                            strong Car
                            span#userResolutionSidebarCar -
                          .mechanic-resolution-sidebar-row
                            strong Address
                            span#userResolutionSidebarAddress -
                          .mechanic-resolution-sidebar-row
                            strong Work
                            span#userResolutionSidebarWork -
                          .mechanic-resolution-sidebar-row
                            strong Total Price
                            span#userResolutionSidebarTotal -

            section.user-view.is-hidden#userSettingsView
              .settings-card.user-settings-card
                .user-settings-layout
                  .dashboard-section.dashboard-section--welcome.settings-section--welcome
                    .settings-header
                      div
                        h2 Welcome back
                        p.user-welcome-name User
                      .user-welcome-corner-wrap
                        h2.user-welcome-corner Account settings
                        p.user-welcome-corner-subtitle Manage your profile and preferences.

                  .settings-section.settings-section--divider
                    .settings-divider

                  .settings-section.settings-section--layout
                    .settings-layout
                      nav.settings-subnav
                        button.settings-subnav-link.active(type="button" data-subview="general") General
                        button.settings-subnav-link(type="button" data-subview="notifications") Notifications
                        button.settings-subnav-link(type="button" data-subview="security") Login & security

                      .settings-panel
                        section.settings-subview#userSettingsGeneral
                          .settings-photo-row
                            .settings-avatar.settings-avatar-lg#userSettingsAvatarSettings AG
                            button.ghost#userSettingsPhotoButton(type="button") Update
                            input.file-input#userSettingsPhotoInput(type="file" accept="image/*")

                          .settings-divider

                          .settings-profile
                            .settings-meta
                              h4 Full name
                              p#userSettingsNameSettings Angel Gomes
                            button.secondary(type="button" data-settings-field="full_name") Update

                          .settings-divider

                          .settings-row
                            div
                              .settings-contact-list
                                .settings-contact-item
                                  .settings-contact-copy
                                    span.settings-contact-label Phone
                                    p#userSettingsPhoneValueSettings -
                                .settings-contact-item
                                  .settings-contact-copy
                                    span.settings-contact-label Username
                                    p#userSettingsUsernameValueSettings -
                                .settings-contact-item
                                  .settings-contact-copy
                                    span.settings-contact-label Email
                                    p#userSettingsEmailValueSettings -
                                .settings-contact-item
                                  .settings-contact-copy
                                    span.settings-contact-label Address
                                    p#userSettingsAddressValueSettings -
                              p.form-error#userSettingsContactMessage(role="alert" aria-live="polite")
                            .settings-contact-actions
                              button.secondary(type="button" data-settings-field="phone") Update
                              button.secondary(type="button" data-settings-field="username") Update
                              button.secondary(type="button" data-settings-field="email") Update
                              button.secondary(type="button" data-settings-field="address") Update

                          .settings-row
                            div
                              h4 Theme
                              p Light mode
                            button.secondary(type="button") Light mode

                          .settings-row
                            div
                              h4 Integration
                              p No integrations connected
                            button.secondary(type="button") Connect

                        section.settings-subview.is-hidden#userSettingsNotifications
                          .notifications-card
                            .notifications-card-head
                              h3 Email Preferences
                            label.notifications-check(for="userNotificationsMarketing")
                              input#userNotificationsMarketing(type="checkbox")
                              span Don't miss out! Subscribe to get special offers/promotions and updates about our services.
                            .notifications-actions
                              button.ghost(type="button") Update

                        section.settings-subview.is-hidden#userSettingsSecurity
                          .security-card
                            .security-card-head
                              h3 Change Password
                            form.security-form#userSecurityPasswordForm
                              label.security-field(for="userSecurityOldPassword")
                                span Old Password
                                input#userSecurityOldPassword(type="password" autocomplete="current-password")
                              label.security-field(for="userSecurityNewPassword")
                                span New Password
                                input#userSecurityNewPassword(type="password" autocomplete="new-password")
                              label.security-field(for="userSecurityConfirmPassword")
                                span Confirm Password
                                input#userSecurityConfirmPassword(type="password" autocomplete="new-password")
                              p.form-error#userSecurityPasswordMessage(role="alert" aria-live="polite")
                              .security-actions
                                button.ghost#userSecurityPasswordSubmit(type="submit") Change

                          .security-card
                            .security-card-head
                              h3 Two Factor Authentication
                            .security-2fa-grid
                              label.security-check
                                input#userSecurity2faEmail(type="checkbox")
                                span Email
                              label.security-check
                                input#userSecurity2faSms(type="checkbox")
                                span SMS
                            .security-actions
                              button.secondary#userSecurity2faEnable(type="button") Enable 2FA
              .settings-edit-modal.is-hidden#userSettingsEditModal
                .settings-edit-backdrop(data-close-modal="true")
                .settings-edit-dialog(role="dialog" aria-modal="true" aria-labelledby="userSettingsEditTitle")
                  .settings-edit-head
                    h3#userSettingsEditTitle Update field
                  p#userSettingsEditDescription Update your information.
                  label.settings-edit-field(for="userSettingsEditInput")
                    span#userSettingsEditLabel Value
                    input#userSettingsEditInput(type="text")
                  .settings-edit-name-grid.is-hidden#userSettingsNameGrid
                    label.settings-edit-field(for="userSettingsEditFirstName")
                      span First name
                      input#userSettingsEditFirstName(type="text")
                    label.settings-edit-field(for="userSettingsEditMiddleName")
                      span Middle name
                      input#userSettingsEditMiddleName(type="text")
                    label.settings-edit-field(for="userSettingsEditLastName")
                      span Last name
                      input#userSettingsEditLastName(type="text")
                  .settings-edit-address-grid.is-hidden#userSettingsAddressGrid
                    label.settings-edit-field(for="userSettingsEditAddressLine1")
                      span Address line 1
                      input#userSettingsEditAddressLine1(type="text")
                    label.settings-edit-field(for="userSettingsEditAddressLine2")
                      span Address line 2
                      input#userSettingsEditAddressLine2(type="text")
                    label.settings-edit-field(for="userSettingsEditCity")
                      span City
                      input#userSettingsEditCity(type="text")
                    label.settings-edit-field(for="userSettingsEditPostcode")
                      span PostCode
                      input#userSettingsEditPostcode(type="text")
                  p.form-error#userSettingsEditMessage(role="alert" aria-live="polite")
                  .settings-edit-actions
                    button.secondary#userSettingsEditCancel(type="button") Cancel
                    button.ghost#userSettingsEditSave(type="button") Update
  include ../../partials/general-footer

