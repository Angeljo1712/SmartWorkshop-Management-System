extends ../../layouts/main

block vars
  - var title = "SmartWorkshop - Mechanic Profile"
  - var bodyClass = "mechanic-edit-body"
  - var activePage = "profile"
  - var profileName = profile && profile.name ? profile.name : "Mechanic"
  - var profileLocation = profile && profile.location ? profile.location : "Surrey"
  - var activeSince = profile && profile.created_at ? new Date(profile.created_at).toLocaleString("en-GB", { month: "long", year: "numeric" }) : "February 2026"
  - var qualifications = profile && profile.qualifications && profile.qualifications.length ? profile.qualifications : ["NVQ Level 3 Qualified"]
  - var yearsExperience = profile && profile.years_experience ? profile.years_experience : 5
  - var jobsDone = profile && profile.jobs_done ? profile.jobs_done : 0
  - var workHistory = profile && profile.work_history ? profile.work_history : "Add your work history to show customers the experience behind your profile."

block head
  link(rel="stylesheet" href="/css/pages/mechanic-edit.css")

block content
  header.main-header.general-header
    .header-content
      a.main-brand(href="/")
        span.main-logo SW
        div
          strong SmartWorkshop
          span Vehicle Service Marketplace

  main.mechanic-edit-shell.primari-shell
    include ./partials/edit-nav.pug

    section.mechanic-edit-main.mechanic-profile-preview
      .mechanic-profile-view-layout
        aside.mechanic-profile-view-sidebar
          .mechanic-profile-avatar-card
            .mechanic-profile-avatar
              if profile && profile.avatar_url
                img(src=profile.avatar_url alt="Profile photo")
              else
                span 🔧
          button.primary.mechanic-profile-cta(type="button") Get A Quote
          .mechanic-profile-info-card
            span (#{jobsDone} ratings)
            ul
              li #{yearsExperience} years professional experience
              li Active since #{activeSince}
          .mechanic-profile-info-card
            h4 Qualifications
            ul
              each q in qualifications
                li= q

        section.mechanic-profile-view-main
          h1 #{profileName}, #{profileLocation} | ClickMechanic
          .mechanic-profile-tabs
            button.active(type="button") Area Covered
          .mechanic-profile-map
            .map-placeholder Map area preview
          .mechanic-profile-about
            h3 Work history
            p= workHistory
